# SmartFoodSave Web Frontend Configuration

# Shared Backend URL (configure this to point to the backend server)
# For development: http://localhost:5000
# For production: https://your-api-domain.com
VITE_API_BASE=http://localhost:5000

# Frontend Firebase Config (Replace in src/firebase.js instead of using .env)
# Get these from Firebase Console > Project Settings > Your apps > Web
# VITE_FIREBASE_API_KEY=your-api-key
# VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=your-project-id
# VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
# VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
# VITE_FIREBASE_APP_ID=1:123456789:web:abc123def456
